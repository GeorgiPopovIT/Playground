{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning"
		}
	},
	"ReverseProxy": {
		"Routes": {
			"product-read": {
				"ClusterId": "new-api",
				"Match": {
					"Path": "products"
				},
				"Transforms": [
					{
						"ResponseHeader": "Served-By",
						"Set": "new-api"
					}
				]
			},
			"all-node": {
				"ClusterId": "old-api",
				"Match": {
					"Path": "{**catch-all}"
				},
				"Transforms": [
					{
						"ResponseHeader": "Served-By",
						"Set": "old-api"
					}
				]
			}
		},
		"Clusters": {
			"old-api": {
				"Destinations": {
					"d1": {
						"Address": "http://localhost:5059"
					}
				}
			},
			"new-api": {
				"Destinations": {
					"d1": {
						"Address": "http://localhost:5066"
					}
				}
			}
		}
	}
}
