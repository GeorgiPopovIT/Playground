@{
    ViewData["Title"] = "Chat - Answers & Responses";
}

<div class="text-center mb-5">
    <h1 class="display-4">Chat & Answers</h1>
    <p class="lead">View responses and chat with the system</p>
</div>

<div class="row">
    <div class="col-12">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-info text-white text-center py-4">
                <h3 class="mb-0">
                    <i class="fas fa-comments me-2"></i>
                    Chat Interface
                </h3>
            </div>
            <div class="card-body p-4">
                <!-- Status Messages -->
                @if (ViewBag.SuccessMessage != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle me-2"></i>
                        @ViewBag.SuccessMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        @ViewBag.ErrorMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (ViewBag.WebhookResponse != null)
                {
                    <div class="alert alert-info alert-dismissible fade show" role="alert">
                        <i class="fas fa-robot me-2"></i>
                        <strong>Webhook Response:</strong> @ViewBag.WebhookResponse
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (ViewBag.TestResult != null)
                {
                    <div class="alert alert-warning alert-dismissible fade show" role="alert">
                        <i class="fas fa-vial me-2"></i>
                        <strong>Webhook Test:</strong> @ViewBag.TestResult
                        @if (ViewBag.TestResponse != null)
                        {
                            <br><small>Response: @ViewBag.TestResponse</small>
                        }
                        @if (ViewBag.TestUrl != null)
                        {
                            <br><small>URL: @ViewBag.TestUrl</small>
                        }
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <!-- Chat Messages Area -->
                <div id="chatMessages" class="chat-messages mb-4" style="height: 400px; overflow-y: auto; border: 1px solid #e0e0e0; border-radius: 10px; padding: 15px; background-color: #f8f9fa;">
                    <div class="message system-message mb-3">
                        <div class="d-flex align-items-start">
                            <div class="avatar me-3">
                                <i class="fas fa-robot text-info"></i>
                            </div>
                            <div class="message-content">
                                <div class="message-bubble system">
                                    <strong>System:</strong> Welcome to the chat! This is where you'll see responses from your email submissions and can interact with the system.
                                </div>
                                <small class="text-muted">@DateTime.Now.ToString("HH:mm")</small>
                            </div>
                        </div>
                    </div>

                    <div class="message user-message mb-3">
                        <div class="d-flex align-items-start">
                            <div class="avatar me-3">
                                <i class="fas fa-user text-primary"></i>
                            </div>
                            <div class="message-content">
                                <div class="message-bubble user">
                                    <strong>You:</strong> Email form submissions and responses will appear here.
                                </div>
                                <small class="text-muted">@DateTime.Now.ToString("HH:mm")</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Chat Input Area -->
                <div class="chat-input">
                    <form asp-action="SendChatMessage" asp-controller="Home" method="post" class="d-flex gap-2">
                        <div class="flex-grow-1">
                            <input name="Message" type="text" class="form-control form-control-lg border-2" 
                                   placeholder="Type your message here..." required />
                            <input name="UserName" type="hidden" value="User" />
                            <input name="MessageType" type="hidden" value="chat" />
                        </div>
                        <button type="submit" class="btn btn-info btn-lg px-4">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>


<style>
    .card {
        border-radius: 15px;
        transition: transform 0.2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-2px);
    }

    .chat-messages {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    }

    .message-bubble {
        padding: 12px 16px;
        border-radius: 18px;
        max-width: 80%;
        word-wrap: break-word;
        margin-bottom: 5px;
    }

    .message-bubble.system {
        background: linear-gradient(135deg, #17a2b8, #138496);
        color: white;
    }

    .message-bubble.user {
        background: linear-gradient(135deg, #007bff, #0056b3);
        color: white;
    }

    .avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0, 123, 255, 0.1);
        font-size: 18px;
    }

    .chat-input input {
        border-radius: 25px;
        transition: all 0.3s ease;
    }

    .chat-input input:focus {
        border-color: #17a2b8;
        box-shadow: 0 0 0 0.2rem rgba(23, 162, 184, 0.25);
    }

    .btn-info {
        border-radius: 50%;
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(45deg, #17a2b8, #138496);
        border: none;
        transition: all 0.3s ease;
    }

    .btn-info:hover {
        transform: scale(1.05);
        box-shadow: 0 5px 15px rgba(23, 162, 184, 0.4);
    }

    .card-header {
        border-radius: 15px 15px 0 0 !important;
    }

    .message-content {
        flex-grow: 1;
    }

    .alert-success {
        border-radius: 10px;
        border: none;
        background: linear-gradient(45deg, #198754, #157347);
        color: white;
    }

    .alert-danger {
        border-radius: 10px;
        border: none;
        background: linear-gradient(45deg, #dc3545, #b02a37);
        color: white;
    }

    .alert-info {
        border-radius: 10px;
        border: none;
        background: linear-gradient(45deg, #0dcaf0, #0aa2c0);
        color: white;
    }
</style>