@model Test_N8n_NET.Models.EmailMessageModel

@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center mb-5">
    <h1 class="display-4">Welcome</h1>
    <p class="lead">Send a message to anyone with our beautiful contact form</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-primary text-white text-center py-4">
                <h3 class="mb-0">
                    <i class="fas fa-envelope me-2"></i>
                    Send Message
                </h3>
            </div>
            <div class="card-body p-5">
                @if (ViewBag.SuccessMessage != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle me-2"></i>
                        @ViewBag.SuccessMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        @ViewBag.ErrorMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-action="Index" asp-controller="Home" method="post" class="needs-validation" novalidate>

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label fw-bold">
                            <i class="fas fa-at me-2 text-primary"></i>
                            Email Address
                        </label>
                        <input asp-for="Email" type="email" class="form-control form-control-lg border-2" 
                               placeholder="Enter recipient's email address" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Subject" class="form-label fw-bold">
                            <i class="fas fa-tag me-2 text-primary"></i>
                            Subject
                        </label>
                        <input asp-for="Subject" type="text" class="form-control form-control-lg border-2" 
                               placeholder="Enter message subject" />
                        <span asp-validation-for="Subject" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Message" class="form-label fw-bold">
                            <i class="fas fa-comment-dots me-2 text-primary"></i>
                            Your Message
                        </label>
                        <textarea asp-for="Message" class="form-control form-control-lg border-2" 
                                  rows="6" placeholder="Type your message here..."></textarea>
                        <span asp-validation-for="Message" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg py-3">
                            <i class="fas fa-paper-plane me-2"></i>
                            Send Message
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border-radius: 15px;
        transition: transform 0.2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-2px);
    }

    .form-control {
        border-radius: 10px;
        transition: all 0.3s ease;
    }

    .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);
        transform: scale(1.02);
    }

    .btn-primary {
        border-radius: 10px;
        background: linear-gradient(45deg, #0d6efd, #0056b3);
        border: none;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(13, 110, 253, 0.3);
    }

    .card-header {
        border-radius: 15px 15px 0 0 !important;
        background: linear-gradient(45deg, #0d6efd, #0056b3) !important;
    }

    .alert-success {
        border-radius: 10px;
        border: none;
        background: linear-gradient(45deg, #198754, #157347);
        color: white;
    }

    .alert-danger {
        border-radius: 10px;
        border: none;
        background: linear-gradient(45deg, #dc3545, #b02a37);
        color: white;
    }
</style>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
